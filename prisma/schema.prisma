generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  VOID
  OVERDUE
}

enum PaymentMethod {
  STRIPE
  PAYSTACK
  CASH
  BANK_TRANSFER
}

enum Provider {
  google
  facebook
  instagram
}

// --- Auth & Core ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  provider      Provider?
  accounts      Account[]
  sessions      Session[]

  // A user account is a business owner
  business Business?

  @@index([email])
  @@index([provider])
}

model Business {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  name        String
  slug        String   @unique
  description String?
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  country     String?
  logoUrl     String?
  latitude    Decimal? @db.Decimal(12, 9)
  longitude   Decimal? @db.Decimal(12, 9)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  services Service[]
  bookings Booking[]
  invoices Invoice[]
  payments Payment[]
  receipts Receipt[]
  gallery  GalleryItem[]

  @@index([ownerId])
  @@index([slug])
}

// --- Business Entities ---

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  businessId  String
  name        String
  description String?
  image String?
  price       Decimal  @db.Decimal(10, 2)
  duration    Int // Duration in minutes
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  invoices     InvoiceService[]
  receipts     ReceiptService[]

  @@index([businessId])
  @@index([slug])
}

// --- Transactions ---

model Booking {
  id         String        @id @default(cuid())
  slug       String        @unique
  businessId String
  serviceId  String
  startTime  DateTime
  endTime    DateTime
  status     BookingStatus @default(PENDING)
  notes      String?

  // Client Details (Snapshot)
  clientName  String
  clientEmail String?
  clientPhone String?

  // OSM Routing fields
  clientLat     Decimal? @db.Decimal(12, 9)
  clientLong    Decimal? @db.Decimal(12, 9)
  distanceKm    Decimal? @db.Decimal(10, 2)
  durationMin   Int?
  routePolyline String?  @db.Text // Encoded polyline for mapping

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id])
  invoice  Invoice?

  @@index([businessId])
  @@index([serviceId])
  @@index([slug])
}


model Invoice {
  id            String        @id @default(cuid())
  slug          String        @unique
  businessId    String
  bookingId     String?       @unique
  invoiceNumber String // e.g., INV-1001
  status        InvoiceStatus @default(DRAFT)
  currency      String        @default("USD")

  // Client Details (Snapshot)
  clientName  String
  clientEmail String?
  clientPhone String?

  // Financial Details
  subtotal   Decimal @db.Decimal(10, 2)
  taxAmount  Decimal @default(0) @db.Decimal(10, 2)
  discount   Decimal @default(0) @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)
  amountPaid Decimal @default(0) @db.Decimal(10, 2)

  dueAt     DateTime?
  sentAt    DateTime?
  paidAt    DateTime?
  notes     String?
  url       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  services InvoiceService[]
  payments Payment[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([bookingId])
  @@index([slug])
}

model Receipt {
  id            String  @id @default(cuid())
  slug          String  @unique
  businessId    String
  paymentId     String? @unique
  receiptNumber String // e.g., RCP-1001

  // Client Details (Snapshot)
  name  String?
  email String?
  phone String?

  // Financial Details
  currency      String         @default("USD")
  subtotal      Decimal        @default(0) @db.Decimal(10, 2)
  taxAmount     Decimal        @default(0) @db.Decimal(10, 2)
  discount      Decimal        @default(0) @db.Decimal(10, 2)
  total         Decimal        @db.Decimal(10, 2)
  amountPaid    Decimal        @db.Decimal(10, 2)
  paymentMethod PaymentMethod?

  notes String?
  url   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  services ReceiptService[]

  @@unique([businessId, receiptNumber])
  @@index([businessId])
  @@index([paymentId])
  @@index([slug])
}

model InvoiceService {
  invoiceId   String
  serviceId   String
  description String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([invoiceId, serviceId])
  @@index([invoiceId])
  @@index([serviceId])
}

model ReceiptService {
  receiptId   String
  serviceId   String
  description String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([receiptId, serviceId])
  @@index([receiptId])
  @@index([serviceId])
}

model Payment {
  id         String        @id @default(cuid())
  businessId String
  invoiceId  String?
  amount     Decimal       @db.Decimal(10, 2)
  method     PaymentMethod
  reference  String?       @unique // External transaction ID

  // Client Details (Snapshot)
  clientName  String?
  clientEmail String?
  clientPhone String?

  createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  receipt  Receipt?

  @@index([businessId])
  @@index([invoiceId])
}




model GalleryItem {
  id         String   @id @default(cuid())
  businessId String
  url        String
  caption    String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// --- Auth.js Internals ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
