generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessCategory {
  FASHION_DESIGN
  LASH_TECHNICIAN
  HAIR_STYLIST
  BARBER
  MAKEUP_ARTIST
  NAIL_TECHNICIAN
  SPA_AND_BEAUTY
  PHOTOGRAPHY
  EVENT_SERVICES
  CONSULTING
  OTHER
}

enum BusinessRole {
  OWNER
  ADMIN
  STAFF
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  VOID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  STRIPE
  FLUTTERWAVE
  BANK_TRANSFER
  CASH
  OTHER
}

enum MapProvider {
  GOOGLE_MAPS
  MAPBOX
  OPENSTREETMAP
  OTHER
}

enum ServiceLocationType {
  BUSINESS_LOCATION
  CLIENT_LOCATION
  VIRTUAL
}

model Business {
  id             String           @id @default(cuid())
  ownerId        String
  name           String
  slug           String           @unique
  category       BusinessCategory @default(OTHER)
  description    String?
  phone          String?
  email          String?
  website        String?
  whatsapp       String?
  city           String?
  state          String?
  country        String           @default("NG")
  currency       String           @default("NGN")
  timezone       String           @default("Africa/Lagos")
  acceptsOnsite  Boolean          @default(true)
  acceptsMobile  Boolean          @default(false)
  acceptsVirtual Boolean          @default(false)
  isPublished    Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  owner             User               @relation("OwnedBusinesses", fields: [ownerId], references: [id], onDelete: Cascade)
  location          Location?          @relation("BusinessLocation")
  profile           BusinessProfile?
  members           BusinessMember[]
  staff             StaffMember[]
  services          Service[]
  bookings          Booking[]
  invoices          Invoice[]
  payments          Payment[]
  availabilityRules AvailabilityRule[]
  serviceAreas      ServiceArea[]

  @@index([ownerId])
  @@index([category])
  @@index([city, state])
  @@index([isPublished])
}

model Location {
  id               String       @id @default(cuid())
  businessId       String?      @unique
  clientId         String?
  label            String?
  formattedAddress String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  country          String       @default("NG")
  postalCode       String?
  latitude         Decimal?     @db.Decimal(9, 6)
  longitude        Decimal?     @db.Decimal(9, 6)
  placeId          String?
  mapProvider      MapProvider?
  routeNotes       String?
  isDefault        Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  business Business? @relation("BusinessLocation", fields: [businessId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([clientId])
  @@index([city, state])
  @@index([latitude, longitude])
  @@index([placeId])
}

model ServiceArea {
  id         String   @id @default(cuid())
  businessId String
  name       String
  city       String?
  state      String?
  country    String   @default("NG")
  latitude   Decimal? @db.Decimal(9, 6)
  longitude  Decimal? @db.Decimal(9, 6)
  radiusKm   Decimal? @db.Decimal(8, 2)
  travelFee  Decimal? @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([city, state])
  @@index([isActive])
}

model BusinessProfile {
  id              String   @id @default(cuid())
  businessId      String   @unique
  headline        String?
  bio             String?
  metaTitle       String?
  metaDescription String?
  searchKeywords  String[]
  logoUrl         String?
  coverImageUrl   String?
  instagramUrl    String?
  tiktokUrl       String?
  facebookUrl     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BusinessMember {
  businessId String
  userId     String
  role       BusinessRole @default(STAFF)
  invitedAt  DateTime     @default(now())
  acceptedAt DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([businessId, userId])
  @@index([userId])
}

model StaffMember {
  id          String   @id @default(cuid())
  businessId  String
  userId      String?
  displayName String
  title       String?
  bio         String?
  email       String?
  phone       String?
  isBookable  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  services StaffService[]
  bookings Booking[]      @relation("BookingStaff")

  @@index([businessId])
  @@index([userId])
}

model Service {
  id              String              @id @default(cuid())
  businessId      String
  name            String
  slug            String
  description     String?
  durationMinutes Int
  bufferMinutes   Int                 @default(0)
  price           Decimal             @db.Decimal(10, 2)
  currency        String              @default("NGN")
  requiresDeposit Boolean             @default(false)
  depositAmount   Decimal?            @db.Decimal(10, 2)
  locationType    ServiceLocationType @default(BUSINESS_LOCATION)
  travelFee       Decimal?            @db.Decimal(10, 2)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff        StaffService[]
  bookings     Booking[]
  invoiceItems InvoiceItem[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([isActive])
}

model StaffService {
  staffId   String
  serviceId String

  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@index([serviceId])
}

model Client {
  id         String   @id @default(cuid())
  businessId String
  name       String
  email      String?
  phone      String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  locations Location[]
  bookings  Booking[]
  payments  Payment[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([phone])
}

model AvailabilityRule {
  id          String    @id @default(cuid())
  businessId  String
  dayOfWeek   DayOfWeek
  startsAt    String
  endsAt      String
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dayOfWeek])
}

model Booking {
  id                     String              @id @default(cuid())
  businessId             String
  serviceId              String
  clientId               String
  staffId                String?
  locationId             String?
  startsAt               DateTime
  endsAt                 DateTime
  status                 BookingStatus       @default(PENDING)
  locationType           ServiceLocationType @default(BUSINESS_LOCATION)
  routeDistanceKm        Decimal?            @db.Decimal(8, 2)
  estimatedTravelMinutes Int?
  routeProvider          MapProvider?
  routePolyline          String?
  routeCalculatedAt      DateTime?
  notes                  String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client   Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  staff    StaffMember? @relation("BookingStaff", fields: [staffId], references: [id], onDelete: SetNull)
  location Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  invoice  Invoice?
  payments Payment[]

  @@index([businessId, startsAt])
  @@index([clientId])
  @@index([locationId])
  @@index([serviceId])
  @@index([staffId])
  @@index([status])
}

model Invoice {
  id            String        @id @default(cuid())
  businessId    String
  clientName    String
  clientEmail   String?
  clientPhone   String?
  bookingId     String?       @unique
  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  currency      String        @default("NGN")
  subtotal      Decimal       @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  amountPaid    Decimal       @default(0) @db.Decimal(10, 2)
  dueAt         DateTime?
  sentAt        DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  items    InvoiceItem[]
  payments Payment[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId, status])
  @@index([clientEmail])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  serviceId   String?
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([serviceId])
}

model Payment {
  id                  String          @id @default(cuid())
  businessId          String
  clientId            String
  invoiceId           String?
  bookingId           String?
  provider            PaymentProvider
  status              PaymentStatus   @default(PENDING)
  amount              Decimal         @db.Decimal(10, 2)
  currency            String          @default("NGN")
  providerReference   String?         @unique
  providerCheckoutUrl String?
  paidAt              DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([clientId])
  @@index([invoiceId])
  @@index([bookingId])
}

// Auth.js adapter models
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts        Account[]
  sessions        Session[]
  ownedBusinesses Business[]       @relation("OwnedBusinesses")
  memberships     BusinessMember[]
  staffProfiles   StaffMember[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
